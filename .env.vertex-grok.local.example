TELEGRAM_BOT_TOKEN=your_telegram_bot_token
AI_BACKEND=vertex-grok
# Prefer these over hardcoding OPENAI_BASE_URL.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Default is global if omitted.
GOOGLE_CLOUD_LOCATION=global
# VERTEX_OPENAI_BASE_URL can override the derived Vertex OpenAI-compatible URL.
GEMINI_MODEL=xai/grok-4.1-fast-non-reasoning
SYSTEM_PROMPT_ENABLED=false
TRIGGER_ALIAS=@grok
SYSTEM_PROMPT_FILE=prompts/grok-balanced.txt
TAVILY_API_KEY=your_tavily_api_key
MAX_HISTORY_MESSAGES=12
SEARCH_MAX_RESULTS=5
MAX_IMAGE_BYTES=8388608
SQLITE_PATH=bot.db
POLL_TIMEOUT_SECONDS=30
