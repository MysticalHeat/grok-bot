TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Vertex Grok backend uses Google ADC / service account auth.
AI_BACKEND=vertex-grok
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/etc/telegram-gemini-bot/service-account.json

# Example Grok model name for Vertex deployment.
GEMINI_MODEL=xai/grok-4.1-fast-non-reasoning

# Optional: keep the system prompt disabled for server deployment.
SYSTEM_PROMPT_ENABLED=false

TRIGGER_ALIAS=@grok
MAX_HISTORY_MESSAGES=12
SEARCH_MAX_RESULTS=5
MAX_IMAGE_BYTES=8388608
SQLITE_PATH=/var/lib/telegram-gemini-bot/bot.db
POLL_TIMEOUT_SECONDS=30

# Not needed for vertex-grok deployment.
# OPENAI_API_KEY=
