TELEGRAM_BOT_TOKEN=your_telegram_bot_token
AI_BACKEND=gemini
GEMINI_API_KEY=your_google_ai_studio_api_key
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# OPENAI_BASE_URL=https://your-openai-compatible-host/v1
# OPENAI_API_KEY=your_bearer_token_or_api_key
# VERTEX_OPENAI_BASE_URL=https://your-vertex-openai-compatible-host/v1
TAVILY_API_KEY=your_tavily_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
TRIGGER_ALIAS=@grok
SYSTEM_PROMPT_FILE=prompts/grok-balanced.txt
# GEMINI_PROXY=http://127.0.0.1:8080
# SYSTEM_PROMPT=Отвечай кратко и по делу на русском языке, если пользователь не просит иначе.
MAX_HISTORY_MESSAGES=12
SEARCH_MAX_RESULTS=5
MAX_IMAGE_BYTES=8388608
SQLITE_PATH=bot.db
POLL_TIMEOUT_SECONDS=30
